{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag":        { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      },
      "required": ["repository", "tag", "pullPolicy"]
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "namespace": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": ["Production", "Development"],
      "description": "ASP.NET Core environment. Development activates the signing endpoint on port 8081; Production is the default for all other deployments."
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      },
      "required": ["port"]
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "publicKey", "privateKeySecret"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "publicKey": {
            "type": "string",
            "minLength": 1
          },
          "privateKeySecret": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "key"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "key":  { "type": "string", "minLength": 1 }
            }
          },
          "algorithms": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "contentHash": {
                "type": "string",
                "enum": ["SHA1", "SHA256", "SHA512"]
              },
              "signingHash": {
                "type": "string",
                "enum": ["HMACSHA1", "HMACSHA256", "HMACSHA512"]
              }
            }
          },
          "nonce": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "maxAgeInSeconds": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "schemes": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "headers": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["name"],
                    "properties": {
                      "name":      { "type": "string", "minLength": 1 },
                      "claimType": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "redis": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "required": ["enabled"]
    },
    "istio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "meshConfig": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "namespace":           { "type": "string", "minLength": 1 },
            "configMapName":       { "type": "string", "minLength": 1 },
            "maxRequestBytes":     { "type": "integer", "minimum": 1 },
            "allowPartialMessage": { "type": "boolean" }
          },
          "required": ["namespace", "configMapName", "maxRequestBytes", "allowPartialMessage"]
        },
        "ingressGateway": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":   { "type": "boolean" },
            "name":      { "type": "string" },
            "namespace": { "type": "string" },
            "authorizationPolicy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" }
              },
              "required": ["enabled"]
            }
          },
          "required": ["enabled", "name", "namespace", "authorizationPolicy"]
        },
        "waypoint": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":   { "type": "boolean" },
            "name":      { "type": "string" },
            "namespace": { "type": "string" },
            "authorizationPolicy": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean" }
              },
              "required": ["enabled"]
            }
          },
          "required": ["enabled", "name", "namespace", "authorizationPolicy"]
        }
      },
      "required": ["enabled", "meshConfig", "ingressGateway", "waypoint"]
    }
  },
  "required": ["image", "replicaCount", "namespace", "environment", "service", "policies", "istio"]
}
